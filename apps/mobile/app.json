{
  "expo": {
    "name": "HoodOps",
    "slug": "hoodops-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": { "image": "./assets/splash-icon.png", "resizeMode": "contain", "backgroundColor": "#1e4d6b" },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.hoodops.mobile", "infoPlist": { "NSCameraUsageDescription": "HoodOps needs camera access for inspection photos", "NSMicrophoneUsageDescription": "HoodOps needs microphone for voice notes", "NSLocationWhenInUseUsageDescription": "HoodOps records your location for job verification" } },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/android-icon-foreground.png", "backgroundImage": "./assets/android-icon-background.png", "monochromeImage": "./assets/android-icon-monochrome.png" }, "package": "com.hoodops.mobile", "permissions": ["CAMERA", "RECORD_AUDIO", "ACCESS_FINE_LOCATION"] },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": ["expo-camera", "expo-location", "expo-secure-store", "expo-sqlite"]
  }
}
