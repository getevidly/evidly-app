  "demo_mode": {
    "context_file": "src/contexts/DemoContext.tsx",
    "provider": "DemoProvider",
    "override_provider": "DemoOverrideProvider (for Role Preview - forces demo mode off for regular layout)",

    "modes": {
      "anonymous_demo": {
        "flag": "isDemoMode = true",
        "storage": "sessionStorage 'evidly_demo_mode' = 'true'",
        "condition": "rawDemoMode && !isAuthenticated",
        "guard_mode": "anonymous_demo"
      },
      "authenticated_demo": {
        "flag": "isAuthenticatedDemo = true",
        "condition": "isAuthenticated && organizations.is_demo = true",
        "fetches": "organizations.is_demo + demo_expires_at on session change",
        "guard_mode": "authenticated_demo"
      },
      "role_preview": {
        "flag": "isDemoMode = true (forced)",
        "condition": "__rolePreview URL param present",
        "detection": "Module-level IIFE _isRolePreview",
        "purpose": "Admin iframe must render tenant layout with demo data"
      }
    },

    "activation": {
      "function": "enterDemo(lead?: DemoLead)",
      "actions": [
        "Clears all Supabase auth tokens from localStorage (sb-*-auth-token)",
        "Signs out from Supabase if session exists",
        "Sets rawDemoMode = true",
        "Tracks 'demo_start' analytics event",
        "Stores 'evidly_demo_mode' = 'true' in sessionStorage",
        "If lead provided: stores lead in sessionStorage + starts tour"
      ]
    },

    "deactivation": {
      "function": "exitDemo()",
      "actions": [
        "Sets rawDemoMode = false",
        "Clears demoLead state",
        "Sets tourActive = false",
        "Removes 'evidly_demo_mode' and 'evidly_demo_lead' from sessionStorage"
      ],
      "auto_cleanup": "When user authenticates while in rawDemoMode, demo state is auto-cleaned (unless in role preview)"
    },

    "conversion": {
      "edge_function": "demo-account-convert",
      "auth": "EvidLY admin only (@getevidly.com)",
      "actions": [
        "Sets organizations.is_demo = false, converted_at = now(), demo_plan = selectedPlan",
        "Updates demo_sessions.status = 'converted'",
        "Deletes demo_generated_data rows linked to demo sessions"
      ],
